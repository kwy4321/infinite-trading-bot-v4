# Toss Securities Open API
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_SEQ=1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# true = API 주문 없이 시뮬레이션 | false + Toss 키 = LIVE
DRY_RUN=true

# --- GCP e2-micro / 무료 티어 (디스크·RAM 절약) ---
LOG_LEVEL=WARNING
BACKUP_ENABLED=true
BACKUP_KEEP=5
BRIEFING_ENABLED=false
MAX_SPLIT_LOG=30
MAX_COMPLETED_CYCLES=50

# Optional (BRIEFING_ENABLED=true 일 때)
NEWS_API_KEY=
SUMMARIZER_API_KEY=
